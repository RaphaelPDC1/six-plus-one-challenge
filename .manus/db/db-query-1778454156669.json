{
  "query": "SELECT p.id, p.displayName, p.totalPoints AS storedPoints, p.daysComplete AS storedDays, COALESCE(dl.logPoints, 0) AS logPoints, COALESCE(dl.completeLogDays, 0) AS completeLogDays, COALESCE(b.boostPoints, 0) AS boostPoints, COALESCE(dl.logPoints, 0) + COALESCE(b.boostPoints, 0) AS canonicalPoints, p.totalPoints - COALESCE(dl.logPoints, 0) AS storedMinusLogPoints, p.daysComplete - COALESCE(dl.completeLogDays, 0) AS storedMinusCompleteDays FROM participants p LEFT JOIN (SELECT participantId, SUM(pointsAwarded) AS logPoints, COUNT(*) AS completeLogDays FROM daily_logs WHERE dayComplete = 1 GROUP BY participantId) dl ON dl.participantId = p.id LEFT JOIN (SELECT user_id, SUM(points_awarded) AS boostPoints FROM boost_wins WHERE challenge_id = 1 GROUP BY user_id) b ON b.user_id = p.id ORDER BY canonicalPoints DESC, completeLogDays DESC, p.displayName ASC LIMIT 30; SELECT dl.id, dl.participantId, p.displayName, dl.dayNumber, dl.dayComplete, dl.pointsAwarded, dl.submittedAt, dl.updatedAt, dl.noAlcohol, dl.cleanEating, dl.exerciseDone, dl.reflectionDone, dl.readTeachDone, dl.trackedEverything FROM daily_logs dl JOIN participants p ON p.id = dl.participantId ORDER BY COALESCE(dl.updatedAt, dl.createdAt) DESC LIMIT 20;",
